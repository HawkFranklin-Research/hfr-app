rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /verifications/{allPaths=**} {
      // Allow clinicians to upload their own verification documents
      allow write: if request.auth != null;
      // Restrict read access to authenticated users (admin can see all)
      allow read: if request.auth != null;
    }
    match /cases/{allPaths=**} {
      // Publicly readable clinical cases
      allow read: if true;
    }
  }
}
